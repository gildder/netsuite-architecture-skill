{
  "compilerOptions": {
    /* Target & Environment */
    "target": "ES2020",
    "module": "AMD",
    "moduleResolution": "Node",
    "esModuleInterop": false,
    "forceConsistentCasingInFileNames": true,
    "lib": ["ESNext"],

    /* Paths & Outputs */
    "rootDir": "src/TypeScripts/[PROJECT_NAME]",
    "outDir": "src/FileCabinet/SuiteScripts/[PROJECT_NAME]",
    "baseUrl": ".",
    "paths": {
      "N": ["node_modules/@hitc/netsuite-types/N"],
      "N/*": ["node_modules/@hitc/netsuite-types/N/*"]
    },

    /* The "Rigor" Guardrails */
    "strict": true,
    "strictNullChecks": true,
    "noImplicitAny": true,
    "noImplicitReturns": true,
    "noUnusedLocals": true,
    "noUnusedParameters": true,

    /* NetSuite Compatibility */
    "skipLibCheck": true,
    "noEmitOnError": true,
    "experimentalDecorators": true
  },
  "include": ["src/TypeScripts/[PROJECT_NAME]/**/*"],
  "exclude": ["node_modules", "src/FileCabinet"]
}